{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoCode",
  "version": "0.2.0",
  "identifier": "com.autocode.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AutoCode",
        "width": 520,
        "height": 680,
        "minWidth": 420,
        "minHeight": 500,
        "center": true,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  }
}
